---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page not found';
const description = 'The page you are looking for does not exist.';
---

<BaseLayout title={title} description={description} robots="noindex, follow">
	<main id="main" class="site-main">
		<div class="not-found">
			<h1 class="not-found__title">404</h1>
			<p class="not-found__lead">This page does not exist or the link has changed.</p>
			<p class="not-found__actions">
				<a class="button button--primary" href="/">Back to home</a>
			</p>
		</div>
	</main>
</BaseLayout>
