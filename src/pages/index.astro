---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Timeline, TimelineItem } from 'webcoreui/astro';

const title = 'Pablo Aragonés López — Lead Software Engineer';
const description =
	'Lead Software Engineer and Senior Backend Developer in Alicante, Spain. Microservices, Spring Boot, and cloud-native systems for Maersk / APM Terminals; technical author at Baeldung.';

const projects: {
	title: string;
	meta: string;
	description: string;
	links: { label: string; href: string }[];
}[] = [
	{
		title: 'Port operations digital twin (Maersk / APM Terminals)',
		meta: 'Java 17/21 · Spring Boot · Spring Cloud · Redis · Docker · Real-time telemetry',
		description:
			'Real-time 3D monitoring for global terminal operations: cranes, vessels, and containers with live telemetry and operational data to improve port logistics and maintenance efficiency.',
		links: [],
	},
	{
		title: 'Technical writing (Baeldung)',
		meta: 'Spring Boot · Microservices · Backend architecture',
		description:
			'Articles and production-style examples for a large Java audience, with supporting GitHub repositories.',
		links: [
			{
				label: 'Author profile',
				href: 'https://www.baeldung.com/author/pabloaragoneslopez',
			},
		],
	},
	{
		title: 'Montana — Real-time mountain incident map',
		meta: 'Next.js · TypeScript · Supabase · PostGIS · PWA · Web Push',
		description:
			'Community map for hikers and mountain sports users to report hazards and useful waypoints, with voting-based validation, real-time updates, and push notifications.',
		links: [
			{
				label: 'Live',
				href: 'https://montana-web.vercel.app/',
			},
			{
				label: 'Repository',
				href: 'https://github.com/Pablo997/montana-web',
			},
		],
	},
	{
		title: 'PulsarDB — Lightweight time-series database',
		meta: 'Go · WAL · Concurrent in-memory engine · REST API · Edge/IoT',
		description:
			'High-throughput time-series database for edge and IoT workloads, focused on low-latency writes/queries and durability via binary WAL.',
		links: [
			{
				label: 'Repository',
				href: 'https://github.com/Pablo997/pulsardb',
			},
		],
	},
];

const publications: { title: string; date: string; href: string }[] = [
	{
		title: 'Handle Spring Security Exceptions',
		date: 'Jan 2024',
		href: 'https://www.baeldung.com/spring-security-exceptions',
	},
	{
		title: '@RequestMapping Value in Properties File',
		date: 'May 2022',
		href: 'https://www.baeldung.com/spring-requestmapping-properties-file',
	},
];

const linkedInUrl =
	'https://www.linkedin.com/in/pablo-aragon%C3%A9s-l%C3%B3pez-07ba3715b';
const tableauUrl = 'https://public.tableau.com/app/profile/pablo.aragon.s.l.pez/vizzes';
/** Update if your GitHub username differs (inferred from your email local part). */
const githubUrl = 'https://github.com/Pablo997';

const siteBase = Astro.site ?? Astro.url;
const personPageUrl = new URL('/', siteBase).href;

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Pablo Aragonés López',
	url: personPageUrl,
	email: 'pabloaragones97@gmail.com',
	jobTitle: 'Lead Software Engineer',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Alicante',
		addressCountry: 'ES',
	},
	sameAs: [
		linkedInUrl,
		tableauUrl,
		githubUrl,
		'https://www.baeldung.com/author/pabloaragoneslopez',
	],
	knowsAbout: [
		'Java',
		'Spring Boot',
		'Microservices',
		'Backend engineering',
		'Cloud-native systems',
	],
};
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
	<header class="site-header">
		<div class="site-header__inner">
			<a class="site-header__brand" href="/">Pablo Aragonés López</a>
			<button
				class="site-header__menu-button js-nav-toggle"
				type="button"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="primary-nav"
			>
				☰
			</button>
			<nav id="primary-nav" class="site-header__nav" aria-label="Primary">
				<a class="site-header__link" href="#about">About</a>
				<a class="site-header__link" href="#experience">Experience</a>
				<a class="site-header__link" href="/projects">Projects</a>
				<a class="site-header__link" href="#writing">Writing</a>
				<a class="site-header__link" href="#contact">Contact</a>
			</nav>
		</div>
	</header>

	<main id="main" class="site-main">
		<section class="hero" aria-labelledby="hero-title">
			<h1 id="hero-title" class="hero__title">Hi, I’m Pablo Aragonés López.</h1>
			<p class="hero__lead">
				Lead Software Engineer with 6+ years building and scaling distributed backend systems in production.
				I design event-driven microservices and lead delivery from architecture to deployment — currently for
				Maersk / APM Terminals platforms used worldwide, processing live telemetry and operational data.
			</p>
			<p class="hero__availability">
				Based in Alicante, Spain · Open to senior backend / architecture conversations · Remote-friendly within
				compatible time zones.
			</p>
			<div class="hero__actions">
				<a class="button button--primary" href="#contact">Get in touch</a>
				<a
					class="button button--ghost"
					href="/pablo-aragones-lopez-cv.pdf"
					download="Pablo_Aragonés_Lopez_CV.pdf">Download CV</a
				>
				<a class="button button--ghost" href="#experience">Experience</a>
			</div>
		</section>

		<section id="about" class="section" aria-labelledby="about-title">
			<h2 id="about-title" class="section__title">About</h2>
			<p class="section__body">
				I’m based in <strong>Alicante, Spain</strong>. My focus is backend architecture, cloud-native development,
				and data-intensive applications — with professional experience in <strong>Node.js (NestJS)</strong> and
				<strong>Python</strong>, and a strong core in <strong>Java</strong> and the Spring ecosystem. I care
				about scalability, resilience, and observability in systems that run 24/7.
			</p>
			<p class="section__body">
				<strong>Education:</strong> Bachelor’s in Computer Engineering (Computation), University of Alicante
				(2015–2019). Machine Learning course at Saturdays.AI (2019–2020). Linguistic immersion in English,
				Universidad Internacional Menéndez Pelayo (2017).
			</p>
			<p class="section__body">
				<strong>Languages:</strong> Spanish (native), English (C1 — daily professional use with international
				clients).
			</p>
			<p class="section__body">
				<strong>Core stack:</strong> Java (8→21), Spring Boot, Spring Cloud, Node.js (NestJS), Python, REST,
				microservices, event-driven design, Docker, Jenkins, SQL Server, PostgreSQL, MongoDB, Redis,
				Elasticsearch, Prometheus, Grafana, ELK, Git. Cloud: AWS, Azure; GCP and Kubernetes in progress.
			</p>
		</section>

		<section id="experience" class="section experience" aria-labelledby="experience-title">
			<h2 id="experience-title" class="section__title">Experience</h2>
			<div class="experience__timeline">
				<Timeline theme="stroke fill">
					<TimelineItem title="Lead Software Engineer — Systems, Servers & Solutions S.L.">
						<p class="experience__period">Jul 2021 — Present</p>
						<ul class="experience__list">
							<li class="experience__item">
								Leading backend development and architecture for Maersk / APM Terminals digital products.
							</li>
							<li class="experience__item">
								Microservice ecosystem with Spring Boot, Spring Cloud, Redis, and Docker for live
								telemetry and transactional data.
							</li>
							<li class="experience__item">
								CI/CD with Jenkins and event-driven patterns across distributed services.
							</li>
							<li class="experience__item">
								Integrations with Ignition, Navis 4, IFS, and SQL Server, plus observability with Prometheus,
								Grafana, and ELK.
							</li>
							<li class="experience__item">
								Mentoring, code reviews, and collaboration with global stakeholders.
							</li>
						</ul>
					</TimelineItem>
					<TimelineItem title="Technical Author — Baeldung">
						<p class="experience__period">Mar 2022 — Present</p>
						<ul class="experience__list">
							<li class="experience__item">
								Authored technical articles on Spring Boot, microservices, and backend architecture.
							</li>
							<li class="experience__item">
								Built production-oriented companion repositories and code examples.
							</li>
							<li class="experience__item">Work read by 100K+ monthly readers across the Java community.</li>
						</ul>
					</TimelineItem>
					<TimelineItem title="Java Software Engineer — Systems, Servers & Solutions S.L.">
						<p class="experience__period">Oct 2019 — Jul 2021</p>
						<ul class="experience__list">
							<li class="experience__item">
								Developed backend services with Spring Boot, Hibernate, and JPA.
							</li>
							<li class="experience__item">Applied TDD and clean architecture in production workflows.</li>
							<li class="experience__item">
								Improved CI/CD with Jenkins and delivered features with frontend, QA, and DevOps teams.
							</li>
						</ul>
					</TimelineItem>
					<TimelineItem title="Backend Developer (Intern) — Aire Networks del Mediterráneo">
						<p class="experience__period">Nov 2018 — Apr 2019</p>
						<ul class="experience__list">
							<li class="experience__item">
								Built backend components for data processing and predictive modelling in the R&amp;D team.
							</li>
							<li class="experience__item">Applied ML/DL techniques for network optimization use cases.</li>
						</ul>
					</TimelineItem>
				</Timeline>
			</div>
		</section>

		<section id="projects" class="section" aria-labelledby="projects-title">
			<h2 id="projects-title" class="section__title">
				Projects
				<a class="section__title-link" href="/projects">See full page</a>
			</h2>
			<ul class="project-list">
				{
					projects.map((p) => (
						<li>
							<article class="project-card">
								<h3 class="project-card__title">{p.title}</h3>
								<p class="project-card__meta">{p.meta}</p>
								<p class="project-card__desc">{p.description}</p>
								{p.links.length > 0 && (
									<div class="project-card__links">
										{p.links.map((link) => (
											<a href={link.href} target="_blank" rel="noopener noreferrer">
												{link.label}
											</a>
										))}
									</div>
								)}
							</article>
						</li>
					))
				}
			</ul>
		</section>

		<section id="writing" class="section" aria-labelledby="writing-title">
			<h2 id="writing-title" class="section__title">Selected publications</h2>
			<p class="section__body">
				Representative tutorials on Baeldung — see the full list on my
				<a href="https://www.baeldung.com/author/pabloaragoneslopez" target="_blank" rel="noopener noreferrer">
					author profile
				</a>.
			</p>
			<ul class="publication-list">
				{
					publications.map((pub) => (
						<li class="publication-list__item">
							<p class="publication-list__meta">Baeldung · {pub.date}</p>
							<p class="publication-list__title">
								<a href={pub.href} target="_blank" rel="noopener noreferrer">
									{pub.title}
								</a>
							</p>
						</li>
					))
				}
			</ul>
		</section>

		<section id="contact" class="contact-band" aria-labelledby="contact-title">
			<div class="contact-band__inner">
				<h2 id="contact-title" class="contact-band__title">Let’s talk</h2>
				<p class="contact-band__lead">
					If you’re building backend platforms or event-driven systems and want a senior engineer on the team,
					reach out.
				</p>
				<div class="contact-band__actions">
					<a class="button button--primary" href="mailto:pabloaragones97@gmail.com">Email me</a>
					<a class="button button--ghost" href="/pablo-aragones-lopez-cv.pdf" download>
						Download CV
					</a>
				</div>
				<ul class="contact-band__links" aria-label="Links">
					<li class="contact-band__item">
						<a class="contact-band__link" href={linkedInUrl} target="_blank" rel="noopener noreferrer">
							LinkedIn
						</a>
					</li>
					<li class="contact-band__item">
						<a class="contact-band__link" href={githubUrl} target="_blank" rel="noopener noreferrer">
							GitHub
						</a>
					</li>
					<li class="contact-band__item">
						<a class="contact-band__link" href={tableauUrl} target="_blank" rel="noopener noreferrer">
							Tableau Public
						</a>
					</li>
				</ul>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="site-footer__inner">
			© {new Date().getFullYear()} Pablo Aragonés López · Alicante, Spain. Built with Astro.
		</div>
	</footer>
</BaseLayout>
