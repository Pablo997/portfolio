---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Timeline, TimelineItem } from 'webcoreui/astro';

const title = 'Pablo Aragonés López — Lead Software Engineer';
const description =
	'Lead Software Engineer and Senior Backend Developer in Alicante, Spain. Microservices, Spring Boot, and cloud-native systems for Maersk / APM Terminals; technical author at Baeldung.';

const projects: {
	title: string;
	outcome: string;
	meta: string;
	description: string;
	links: { label: string; href: string }[];
}[] = [
	{
		title: 'Port operations digital twin (Maersk / APM Terminals)',
		outcome: 'Outcome: Improved operational visibility for global terminal workflows with live telemetry.',
		meta: 'Java 17/21 · Spring Boot · Spring Cloud · Redis · Docker · Real-time telemetry',
		description:
			'Real-time 3D monitoring for global terminal operations: cranes, vessels, and containers with live telemetry and operational data to improve port logistics and maintenance efficiency.',
		links: [],
	},
	{
		title: 'Technical writing (Baeldung)',
		outcome: 'Outcome: Shared production-grade backend patterns to a large Java engineering audience.',
		meta: 'Spring Boot · Microservices · Backend architecture',
		description:
			'Articles and production-style examples for a large Java audience, with supporting GitHub repositories.',
		links: [
			{
				label: 'Author profile',
				href: 'https://www.baeldung.com/author/pabloaragoneslopez',
			},
		],
	},
	{
		title: 'Montana — Real-time mountain incident map',
		outcome: 'Outcome: Reduced hazard reporting friction with real-time, community-validated incident flows.',
		meta: 'Next.js · TypeScript · Supabase · PostGIS · PWA · Web Push',
		description:
			'Community map for hikers and mountain sports users to report hazards and useful waypoints, with voting-based validation, real-time updates, and push notifications.',
		links: [
			{
				label: 'Live',
				href: 'https://montana-web.vercel.app/',
			},
			{
				label: 'Repository',
				href: 'https://github.com/Pablo997/montana-web',
			},
		],
	},
	{
		title: 'PulsarDB — Lightweight time-series database',
		outcome: 'Outcome: Enabled low-latency ingestion and queries for edge/IoT time-series workloads.',
		meta: 'Go · WAL · Concurrent in-memory engine · REST API · Edge/IoT',
		description:
			'High-throughput time-series database for edge and IoT workloads, focused on low-latency writes/queries and durability via binary WAL.',
		links: [
			{
				label: 'Repository',
				href: 'https://github.com/Pablo997/pulsardb',
			},
		],
	},
];

const featuredProject = {
	title: 'Montana — Real-time mountain incident map',
	kicker: 'Featured project',
	outcome: 'Outcome: Reduced hazard reporting friction with real-time, community-validated incident flows.',
	description:
		'Community map for hikers and mountain sports users to report hazards and useful waypoints, with voting-based validation, real-time updates, and push notifications.',
	meta: 'Next.js · TypeScript · Supabase · PostGIS · PWA · Web Push',
	imageSrc: '/projects/montana-web-cover.svg',
	imageAlt: 'Abstract mountain cover for Montana project',
	links: [
		{ label: 'Live', href: 'https://montana-web.vercel.app/' },
		{ label: 'Repository', href: 'https://github.com/Pablo997/montana-web' },
	],
};

const linkedInUrl =
	'https://www.linkedin.com/in/pablo-aragon%C3%A9s-l%C3%B3pez-07ba3715b';
const tableauUrl = 'https://public.tableau.com/app/profile/pablo.aragon.s.l.pez/vizzes';
/** Update if your GitHub username differs (inferred from your email local part). */
const githubUrl = 'https://github.com/Pablo997';

const siteBase = Astro.site ?? Astro.url;
const personPageUrl = new URL('/', siteBase).href;

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Pablo Aragonés López',
	url: personPageUrl,
	email: 'pabloaragones97@gmail.com',
	jobTitle: 'Lead Software Engineer',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Alicante',
		addressCountry: 'ES',
	},
	sameAs: [
		linkedInUrl,
		tableauUrl,
		githubUrl,
		'https://www.baeldung.com/author/pabloaragoneslopez',
	],
	knowsAbout: [
		'Java',
		'Spring Boot',
		'Microservices',
		'Backend engineering',
		'Cloud-native systems',
	],
};
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
	<header class="site-header">
		<div class="site-header__inner">
			<a class="site-header__brand" href="/">Pablo Aragonés López</a>
			<button
				class="site-header__menu-button js-nav-toggle"
				type="button"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="primary-nav"
			>
				☰
			</button>
			<nav id="primary-nav" class="site-header__nav" aria-label="Primary">
				<a class="site-header__link" href="#about">About</a>
				<a class="site-header__link" href="/projects">Projects</a>
				<a class="site-header__link" href="#experience">Case studies</a>
				<a class="site-header__link" href="#contact">Contact</a>
			</nav>
		</div>
	</header>

	<main id="main" class="site-main">
		<section class="hero" aria-labelledby="hero-title">
			<h1 id="hero-title" class="hero__title">Hi, I’m Pablo Aragonés López.</h1>
			<p class="hero__lead">
				Lead Software Engineer with 6+ years building and scaling distributed backend systems in production.
				I design event-driven microservices and lead delivery from architecture to deployment — currently for
				Maersk / APM Terminals platforms used worldwide, processing live telemetry and operational data.
			</p>
			<p class="hero__availability">
				Based in Alicante, Spain · Open to senior backend / architecture conversations · Remote-friendly within
				compatible time zones.
			</p>
			<p class="hero__proof">
				Built for Maersk / APM Terminals · Baeldung author · 6+ years shipping backend systems.
			</p>
			<div class="hero__actions">
				<a class="button button--primary" href="#contact">Get in touch</a>
				<a class="button button--ghost" href="/projects">View projects</a>
				<a class="button button--ghost" href="#experience">See impact</a>
			</div>
		</section>

		<section id="about" class="section" aria-labelledby="about-title">
			<h2 id="about-title" class="section__title">About</h2>
			<p class="section__body">
				I build backend systems for high-throughput, high-availability environments where reliability matters as
				much as delivery speed. My focus is platform architecture, event-driven workflows, and operational
				excellence in production.
			</p>
			<ul class="about-focus-list">
				<li class="about-focus-list__item">
					Designing resilient services with explicit trade-offs around consistency, latency, and scale.
				</li>
				<li class="about-focus-list__item">
					Building event-driven systems with strong observability, clear ownership boundaries, and operational
					guardrails.
				</li>
				<li class="about-focus-list__item">
					Leading implementation from architecture to production, including mentoring and code quality practices.
				</li>
			</ul>
			<p class="section__body about__closing">
				Currently open to senior backend / platform opportunities where architecture and execution both matter.
			</p>
		</section>

		<section id="projects" class="section" aria-labelledby="projects-title">
			<h2 id="projects-title" class="section__title">
				Projects
				<a class="section__title-link" href="/projects">See full page</a>
			</h2>
			<article class="project-featured">
				<div class="project-featured__media">
					<img src={featuredProject.imageSrc} alt={featuredProject.imageAlt} loading="lazy" />
				</div>
				<div class="project-featured__content">
					<p class="project-featured__kicker">{featuredProject.kicker}</p>
					<h3 class="project-featured__title">{featuredProject.title}</h3>
					<p class="project-featured__outcome">{featuredProject.outcome}</p>
					<p class="project-featured__desc">{featuredProject.description}</p>
					<p class="project-featured__meta">{featuredProject.meta}</p>
					<div class="project-featured__links">
						{featuredProject.links.map((link) => (
							<a href={link.href} target="_blank" rel="noopener noreferrer">
								{link.label}
							</a>
						))}
					</div>
				</div>
			</article>
			<ul class="project-list">
				{
					projects.filter((p) => p.title !== featuredProject.title).map((p) => (
						<li>
							<article class="project-card">
								<h3 class="project-card__title">{p.title}</h3>
								<p class="project-card__outcome">{p.outcome}</p>
								<p class="project-card__meta">{p.meta}</p>
								<p class="project-card__desc">{p.description}</p>
								{p.links.length > 0 && (
									<div class="project-card__links">
										{p.links.map((link) => (
											<a href={link.href} target="_blank" rel="noopener noreferrer">
												{link.label}
											</a>
										))}
									</div>
								)}
							</article>
						</li>
					))
				}
			</ul>
		</section>

		<section id="experience" class="section experience" aria-labelledby="experience-title">
			<h2 id="experience-title" class="section__title">Case studies</h2>
			<div class="experience__timeline">
				<Timeline theme="stroke fill">
					<TimelineItem title="Global terminal operations platform (Maersk / APM Terminals)">
						<ul class="experience__list">
							<li class="experience__item">
								<strong>Role:</strong> Technical lead for backend architecture and delivery.
							</li>
							<li class="experience__item">
								<strong>Scope:</strong> Distributed services for live telemetry and transactional
								operations.
							</li>
							<li class="experience__item">
								<strong>Constraints:</strong> High reliability requirements, industrial integrations, and
								24/7 operations.
							</li>
							<li class="experience__item">
								<strong>Outcome:</strong> More reliable delivery cycles and stronger observability
								standards across teams.
							</li>
						</ul>
					</TimelineItem>
					<TimelineItem title="Backend knowledge at scale (Baeldung)">
						<ul class="experience__list">
							<li class="experience__item">
								<strong>Role:</strong> Technical author for backend architecture topics.
							</li>
							<li class="experience__item">
								<strong>Scope:</strong> Spring Boot, microservices, and production-style implementation
								patterns.
							</li>
							<li class="experience__item">
								<strong>Outcome:</strong> Practical guides that help engineers implement backend patterns
								with confidence.
							</li>
						</ul>
					</TimelineItem>
					<TimelineItem title="Production backend foundations (S3)">
						<ul class="experience__list">
							<li class="experience__item">
								<strong>Role:</strong> Backend engineer shipping production services.
							</li>
							<li class="experience__item">
								<strong>Scope:</strong> Service design, implementation, testing, and release pipelines.
							</li>
							<li class="experience__item">
								<strong>Outcome:</strong> Better maintainability and smoother cross-team delivery.
							</li>
						</ul>
					</TimelineItem>
				</Timeline>
			</div>
		</section>

		<section id="now" class="section" aria-labelledby="now-title">
			<h2 id="now-title" class="section__title">Now</h2>
			<p class="section__body">
				I’m currently focused on backend platform work: event-driven architectures, operational reliability, and
				clear engineering ownership. I’m also deepening Kubernetes and GCP to complement my production experience
				on AWS and Azure.
			</p>
		</section>

		<section id="contact" class="contact-band" aria-labelledby="contact-title">
			<div class="contact-band__inner">
				<h2 id="contact-title" class="contact-band__title">Let’s talk</h2>
				<p class="contact-band__lead">
					If you’re building backend platforms or event-driven systems and want a senior engineer on the team,
					reach out.
				</p>
				<div class="contact-band__actions">
					<a class="button button--primary" href="mailto:pabloaragones97@gmail.com">Email me</a>
					<a class="button button--ghost" href="/projects">Browse projects</a>
				</div>
				<ul class="contact-band__links" aria-label="Links">
					<li class="contact-band__item">
						<a class="contact-band__link" href={linkedInUrl} target="_blank" rel="noopener noreferrer">
							LinkedIn
						</a>
					</li>
					<li class="contact-band__item">
						<a class="contact-band__link" href={githubUrl} target="_blank" rel="noopener noreferrer">
							GitHub
						</a>
					</li>
					<li class="contact-band__item">
						<a class="contact-band__link" href={tableauUrl} target="_blank" rel="noopener noreferrer">
							Tableau Public
						</a>
					</li>
				</ul>
			</div>
		</section>
	</main>
	<a class="mobile-contact-cta" href="mailto:pabloaragones97@gmail.com">Email me</a>

	<footer class="site-footer">
		<div class="site-footer__inner">
			© {new Date().getFullYear()} Pablo Aragonés López · Alicante, Spain. Built with Astro.
			<span aria-hidden="true"> · </span>
			<a
				class="site-footer__link"
				href="https://www.baeldung.com/author/pabloaragoneslopez"
				target="_blank"
				rel="noopener noreferrer">Writing</a
			>
		</div>
	</footer>
</BaseLayout>
